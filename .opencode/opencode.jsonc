{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "gasty-dev",
  "agent": {
    "gasty-dev": {
      "prompt": "{file:./agent/gasty-dev.md}",
      "mode": "primary",
      "temperature": 0.2,
      "description": "Default implementer. Builds features, components, hooks, UI. Delegates review and testing.",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "ask",
          "npm run dev": "allow",
          "npm run lint": "allow",
          "npm run build": "allow",
          "npm run preview": "allow",
          "git status*": "allow",
          "git diff*": "allow"
        },
        "task": {
          "gasty-review": "allow",
          "gasty-test": "allow"
        }
      }
    },
    "gasty-review": {
      "prompt": "{file:./agent/gasty-review.md}",
      "mode": "subagent",
      "temperature": 0.1,
      "description": "Reviews code, authors ADRs, enforces bundle budget and anti-patterns.",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow"
        },
        "task": "deny"
      }
    },
    "gasty-test": {
      "prompt": "{file:./agent/gasty-test.md}",
      "mode": "subagent",
      "temperature": 0.1,
      "description": "Writes tests, validates data layer, reviews parser changes.",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "deny",
          "npm test*": "allow",
          "npm run test:watch*": "allow",
          "vitest*": "allow"
        },
        "task": "deny"
      }
    }
  }
}
